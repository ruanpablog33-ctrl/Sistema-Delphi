program Prj_Login;

uses
  Vcl.Forms,
  UnitLancamentos in 'UnitLancamentos.pas' {frmLancamentos},
  UnitOrcamento in 'UnitOrcamento.pas' {frmOrcamento},
  Vcl.Controls, // Necessário para mrOk
  uLogin in 'uLogin.pas' {frmLogin}; // Seu formulário de login

{$R *.res}

begin
  Application.Initialize;
  Application.MainFormOnTaskbar := True;

  // Cria o formulário de login (mas năo o exibe ainda)
  frmLogin := TfrmLogin.Create(nil);
  try
    // Exibe o login. O código para aqui até o usuário clicar ou fechar.
    // Se o usuário clicou em "Entrar" e o ModalResult foi mrOk:
    if frmLogin.ShowModal = mrOk then
    begin
      // Cria o formulário principal e roda a aplicaçăo
  Application.CreateForm(TfrmLancamentos, frmLancamentos);
  Application.CreateForm(TfrmOrcamento, frmOrcamento);
  Application.Run;
    end
    else
    begin
      // Se o usuário fechou ou cancelou, a aplicaçăo morre aqui.
      Application.Terminate;
    end;
  finally
    // Libera o formulário de login da memória
    frmLogin.Free;
  end;
end.
