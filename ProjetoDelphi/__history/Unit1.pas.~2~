unit Unit1;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.Grids;

type
  TFormLista = class(TForm)
    sgTransacoes: TStringGrid;
    procedure FormCreate(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
    // Criamos este procedimento para receber dados de fora
    procedure AdicionarTransacao(Desc, Valor, Data, Tipo, Categ: string);
  end;

var
  FormLista: TFormLista;

implementation

{$R *.dfm}

procedure TFormLista.FormCreate(Sender: TObject);
begin
  // Configura o cabeÁalho
  sgTransacoes.Cells[0, 0] := 'DescriÁ„o';
  sgTransacoes.Cells[1, 0] := 'Valor';
  sgTransacoes.Cells[2, 0] := 'Data';
  sgTransacoes.Cells[3, 0] := 'Tipo';
  sgTransacoes.Cells[4, 0] := 'Categoria';

  // Largura das colunas (opcional)
  sgTransacoes.ColWidths[0] := 200;
end;

// Este ť o mťtodo que a Tela 1 vai chamar
procedure TFormLista.AdicionarTransacao(Desc, Valor, Data, Tipo, Categ: string);
var
  NovaLinha: Integer;
begin
  sgTransacoes.RowCount := sgTransacoes.RowCount + 1;
  NovaLinha := sgTransacoes.RowCount - 1;

  sgTransacoes.Cells[0, NovaLinha] := Desc;
  sgTransacoes.Cells[1, NovaLinha] := Valor;
  sgTransacoes.Cells[2, NovaLinha] := Data;
  sgTransacoes.Cells[3, NovaLinha] := Tipo;
  sgTransacoes.Cells[4, NovaLinha] := Categ;
end;

end.
