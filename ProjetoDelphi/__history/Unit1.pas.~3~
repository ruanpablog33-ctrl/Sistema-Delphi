unit Unit2;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.Grids;

type
  TForm2 = class(TForm) // <--- Voltamos para o nome padr„o
    sgTransacoes: TStringGrid;
    procedure FormCreate(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
    procedure AdicionarTransacao(Desc, Valor, Data, Tipo, Categ: string);
  end;

var
  Form2: TForm2; // <--- Vari·vel padr„o

implementation

{$R *.dfm}

procedure TForm2.FormCreate(Sender: TObject);
begin
  // Configura cabeÁalhos
  sgTransacoes.Cells[0, 0] := 'DescriÁ„o';
  sgTransacoes.Cells[1, 0] := 'Valor';
  sgTransacoes.Cells[2, 0] := 'Data';
  sgTransacoes.Cells[3, 0] := 'Tipo';
  sgTransacoes.Cells[4, 0] := 'Categoria';

  sgTransacoes.ColWidths[0] := 200;
end;

procedure TForm2.AdicionarTransacao(Desc, Valor, Data, Tipo, Categ: string);
var
  NovaLinha: Integer;
begin
  sgTransacoes.RowCount := sgTransacoes.RowCount + 1;
  NovaLinha := sgTransacoes.RowCount - 1;

  sgTransacoes.Cells[0, NovaLinha] := Desc;
  sgTransacoes.Cells[1, NovaLinha] := Valor;
  sgTransacoes.Cells[2, NovaLinha] := Data;
  sgTransacoes.Cells[3, NovaLinha] := Tipo;
  sgTransacoes.Cells[4, NovaLinha] := Categ;
end;

end.
