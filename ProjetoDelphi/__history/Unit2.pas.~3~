unit Unit2;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, Vcl.ExtCtrls, Vcl.ComCtrls;

type
  TFormCadastroTransacao = class(TForm)
    lblTitulo: TLabel;
    edtDescricao: TEdit;
    edtValor: TEdit;
    dtpData: TDateTimePicker;
    rgTipo: TRadioGroup;
    cbCategoria: TComboBox;
    cbPagamento: TComboBox;
    btnSalvar: TButton;
    btnCancelar: TButton;

    // Eventos
    procedure FormCreate(Sender: TObject);
    procedure btnSalvarClick(Sender: TObject);
    procedure btnCancelarClick(Sender: TObject);
    procedure edtValorExit(Sender: TObject);
    procedure edtValorKeyPress(Sender: TObject; var Key: Char);
  private
    { Private declarations }
    function ValidarCampos: Boolean;
    procedure LimparCampos;
  public
    { Public declarations }
  end;

var
  FormCadastroTransacao: TFormCadastroTransacao;

implementation

{$R *.dfm}

uses Unit1;

// Configura鈬o Inicial
procedure TFormCadastroTransacao.FormCreate(Sender: TObject);
begin
  self.Caption := 'Gest縊 Financeira';
  self.Position := poScreenCenter;
  dtpData.Date := Date; // Data atual
  rgTipo.ItemIndex := 1; // Padr縊: Despesa
end;

// Formata o valor para Moeda ao sair do campo
procedure TFormCadastroTransacao.edtValorExit(Sender: TObject);
var
  Valor: Double;
begin
  if TryStrToFloat(StringReplace(edtValor.Text, 'R$', '', [rfReplaceAll]), Valor) then
    edtValor.Text := FormatFloat('R$ #,##0.00', Valor)
  else
    edtValor.Text := '0,00';
end;

// Permite apenas n伹eros e v叝gula no campo de valor
procedure TFormCadastroTransacao.edtValorKeyPress(Sender: TObject; var Key: Char);
begin
  if not (Key in ['0'..'9', ',', #8]) then
    Key := #0;
end;

procedure TFormCadastroTransacao.btnSalvarClick(Sender: TObject);
var
  CategTexto: string;
begin
  // 1. Valida鈬o (Se estiver vazio, para tudo)
  if not ValidarCampos then Exit;

  // 2. Prepara o texto da Categoria (Para evitar erro se n縊 tiver nada selecionado)
  if cbCategoria.ItemIndex >= 0 then
    CategTexto := cbCategoria.Items[cbCategoria.ItemIndex]
  else
    CategTexto := '-';

  // 3. AQUI ﾉ A PARTE IMPORTANTE (ENVIO PARA A TELA 2)
  // Estamos chamando aquele comando "AdicionarTransacao" que criamos na Unit2
  FormLista.AdicionarTransacao(
      edtDescricao.Text,              // Envia a Descri鈬o
      edtValor.Text,                  // Envia o Valor
      DateToStr(dtpData.Date),        // Envia a Data (convertida para texto)
      rgTipo.Items[rgTipo.ItemIndex], // Envia o Tipo (Receita/Despesa)
      CategTexto                      // Envia a Categoria
  );

  // 4. Feedback visual
  ShowMessage('Salvo e enviado para a lista!');

  // 5. Limpa a tela de cadastro para a prima
  LimparCampos;
  edtDescricao.SetFocus;
end;

procedure TFormCadastroTransacao.btnCancelarClick(Sender: TObject);
begin
  Close;
end;

// Fun鋏es Auxiliares
function TFormCadastroTransacao.ValidarCampos: Boolean;
begin
  Result := False;
  if Trim(edtDescricao.Text) = '' then
  begin
    ShowMessage('Por favor, informe uma descri鈬o.');
    edtDescricao.SetFocus;
    Exit;
  end;

  if (Trim(edtValor.Text) = '') or (edtValor.Text = '0,00') then
  begin
    ShowMessage('Por favor, informe um valor v疝ido.');
    edtValor.SetFocus;
    Exit;
  end;

  Result := True;
end;

procedure TFormCadastroTransacao.LimparCampos;
begin
  edtDescricao.Clear;
  edtValor.Clear;
  dtpData.Date := Date;
  cbCategoria.ItemIndex := -1;
  cbPagamento.ItemIndex := -1;
end;

end.
