unit uPrincipal;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.ExtCtrls, Vcl.StdCtrls;

type
  TfrmPrincipal = class(TForm)
    pnlMenu: TPanel;
    pnlAreaTrabalho: TPanel;
    btnLancamentos: TButton;
    btnOrcamento: TButton;
    btnSair: TButton;
    procedure btnSairClick(Sender: TObject);
    procedure btnLancamentosClick(Sender: TObject);
    procedure btnOrcamentoClick(Sender: TObject);
  private
    { Private declarations }
    // Procedimento genÈrico para abrir qualquer tela dentro do painel
    procedure AbrirForm(AFormClass: TComponentClass; var AForm);
  public
    { Public declarations }
  end;

var
  frmPrincipal: TfrmPrincipal;

implementation

{$R *.dfm}
// ADICIONE ESTA LINHA:
uses
  UnitLancamentos, UnitOrcamento;

// Adicione as Units das telas que ser„o chamadas
uses
  UnitLancamentos, UnitOrcamento;

{ TfrmPrincipal }

procedure TfrmPrincipal.AbrirForm(AFormClass: TComponentClass; var AForm);
begin
  // 1. Verifica se a tela j· est· aberta
  if Assigned(TForm(AForm)) then
  begin
    // Se existir, traz para frente e foca
    TForm(AForm).BringToFront;
    TForm(AForm).SetFocus;
  end
  else
  begin
    // 2. Se n„o existir, cria a tela
    Application.CreateForm(AFormClass, AForm);

    with TForm(AForm) do
    begin
      // ConfiguraÁes para a tela se comportar como um painel filho
      Parent := pnlAreaTrabalho; // Define quem È o "Pai" visual
      Align := alClient;         // Preenche todo o espaÁo
      BorderStyle := bsNone;     // Remove bordas e barra de tÌtulo
      Show;                      // Exibe a tela
    end;
  end;
end;

procedure TfrmPrincipal.btnLancamentosClick(Sender: TObject);
begin
  // Chama o mÈtodo genÈrico passando a CLASSE e a VARI¡VEL do form
  AbrirForm(TfrmLancamentos, frmLancamentos);
end;

procedure TfrmPrincipal.btnOrcamentoClick(Sender: TObject);
begin
  AbrirForm(TfrmOrcamento, frmOrcamento);
end;

procedure TfrmPrincipal.btnSairClick(Sender: TObject);
begin
  // Fecha o sistema todo
  Application.Terminate;
end;

end.
